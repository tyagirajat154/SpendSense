   ],
   "source": [
    "# Prepare data for Prophet (needs columns 'ds' and 'y')\n",
    "forecast_df = df[['Date', 'Amount']].rename(columns={'Date': 'ds', 'Amount': 'y'})\n",
    "\n",
    "# Build and train the model\n",
    "model = Prophet()\n",
    "model.fit(forecast_df)\n",
    "\n",
    "# Create future dates (next 30 days)\n",
    "future = model.make_future_dataframe(periods=30)\n",
    "\n",
    "# Predict\n",
    "forecast = model.predict(future)\n",
    "\n",
    "# Plot the forecast\n",
    "model.plot(forecast)\n",
    "plt.title('Prophet: 30-Day Expense Forecast', fontsize=13, fontweight='bold')\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
  },
