   "source": [
    "# Load the dataset\n",
    "df = pd.read_csv('expense_data_1.csv')\n",
    "\n",
    "# Rename columns\n",
    "df = df.rename(columns={\n",
    "    'Date': 'Date',\n",
    "    'Category': 'Category',\n",
    "    'Amount': 'Amount',\n",
    "    'Account': 'Payment_Mode',\n",
    "    'Note': 'Description'\n",
    "})\n",
    "\n",
    "# Keep only relevant columns\n",
    "df = df[['Date', 'Category', 'Amount', 'Payment_Mode', 'Description', 'Income/Expense']]\n",
    "\n",
    "# Keep only expense rows\n",
    "df = df[df['Income/Expense'] == 'Expense'].copy()\n",
    "df = df.drop(columns=['Income/Expense'])\n",
    "\n",
    "# Clean payment mode label\n",
    "df['Payment_Mode'] = df['Payment_Mode'].replace({'CUB - online payment': 'UPI/Online'})\n",
    "\n",
    "# Convert Date to datetime\n",
    "df['Date'] = pd.to_datetime(df['Date'])\n",
    "\n",
    "# Add Month number and Month Name\n",
    "df['Month'] = df['Date'].dt.month\n",
    "df['Month_Name'] = df['Date'].dt.strftime('%B')\n",
    "\n",
    "df = df.reset_index(drop=True)\n",
    "df.head()"
   ]
  },
