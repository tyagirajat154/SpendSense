   "source": [
    "## 15. KMeans Clustering – Spending Behaviour Groups\n",
    "\n",
    "KMeans groups transactions into 3 clusters based on amount and category. This helps identify low, medium, and high spenders."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 19,
   "id": "e6a7c506",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Cluster-wise average spending:\n",
      "Cluster_Label\n",
      "High Spend      4690.00\n",
      "Low Spend        145.24\n",
      "Medium Spend    1418.48\n",
      "Name: Amount, dtype: float64\n"
     ]
    }
   ],
   "source": [
    "le = LabelEncoder()\n",
    "df['Category_encoded'] = le.fit_transform(df['Category'])\n",
    "\n",
    "X_cluster = df[['Amount', 'Category_encoded']]\n",
    "\n",
    "kmeans = KMeans(n_clusters=3, random_state=42, n_init=10)\n",
    "df['Cluster'] = kmeans.fit_predict(X_cluster)\n",
    "\n",
    "# Assign labels based on centroid amount (low to high)\n",
    "centers = kmeans.cluster_centers_\n",
    "sorted_idx = centers[:, 0].argsort()\n",
    "label_map = {\n",
    "    int(sorted_idx[0]): 'Low Spend',\n",
    "    int(sorted_idx[1]): 'Medium Spend',\n",
    "    int(sorted_idx[2]): 'High Spend'\n",
    "}\n",
    "df['Cluster_Label'] = df['Cluster'].map(label_map)\n",
    "\n",
    "print('Cluster-wise average spending:')\n",
    "print(df.groupby('Cluster_Label')['Amount'].mean().round(2))"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 20,
