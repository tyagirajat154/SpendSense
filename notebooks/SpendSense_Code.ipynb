    "## 13. Linear Regression – Predicting Monthly Spending\n",
    "\n",
    "We use Linear Regression to find the trend in monthly spending over time. The model is trained on the available months and the predicted line shows whether spending is going up or down."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 16,
   "id": "ef1532eb",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Mean Absolute Error (MAE) : Rs 7129.00\n",
      "R2 Score                  : 0.0862\n"
     ]
    },
    {
     "data": {
      "image/png": "",
      "text/plain": [
       "<Figure size 900x500 with 1 Axes>"
      ]
     },
     "metadata": {},
     "output_type": "display_data"
    }
   ],
   "source": [
    "# Aggregate total spending per month\n",
    "monthly_ml = df.groupby('Month')['Amount'].sum().reset_index()\n",
    "monthly_ml.columns = ['Month', 'Total_Amount']\n",
    "\n",
    "X = monthly_ml[['Month']]\n",
    "y = monthly_ml['Total_Amount']\n",
    "\n",
    "# Train the model\n",
    "lr = LinearRegression()\n",
    "lr.fit(X, y)\n",
    "y_pred = lr.predict(X)\n",
    "\n",
    "# Evaluation\n",
    "mae = mean_absolute_error(y, y_pred)\n",
    "r2  = r2_score(y, y_pred)\n",
    "\n",
    "print(f'Mean Absolute Error (MAE) : Rs {mae:.2f}')\n",
    "print(f'R2 Score                  : {r2:.4f}')\n",
    "\n",
    "# Plot\n",
    "month_labels = ['Jan','Feb','Mar','Apr','May','Jun',\n",
    "                'Jul','Aug','Sep','Oct','Nov','Dec']\n",
    "x_labels = [month_labels[m-1] for m in monthly_ml['Month']]\n",
    "\n",
    "plt.figure(figsize=(9, 5))\n",
    "plt.plot(x_labels, y.values, 'o-', label='Actual Spending',\n",
    "         color='steelblue', linewidth=2)\n",
    "plt.plot(x_labels, y_pred, 's--', label='Regression Line',\n",
    "         color='tomato', markersize=8)\n",
    "plt.title('Linear Regression: Monthly Spending Trend', fontsize=13, fontweight='bold')\n",
    "plt.xlabel('Month')\n",
    "plt.ylabel('Total Expense (INR)')\n",
    "plt.xticks(rotation=45)\n",
    "plt.legend()\n",
    "plt.grid(True, linestyle='--', alpha=0.5)\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
